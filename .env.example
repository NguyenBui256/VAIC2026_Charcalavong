# VAIC environment variables
# Copy to .env and fill in real values. Never commit .env.

# === Infrastructure (docker-compose) ===
POSTGRES_USER=vaic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vaic
POSTGRES_PORT=5432
REDIS_PORT=6379

# === Backend ===
# Sync SQLAlchemy URL (per architecture: sync mode) — Story 1.2 wires engine
DATABASE_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic
REDIS_URL=redis://localhost:6379/0
VAIC_AUDIT_MASTER_KEY=

# === Auth (Story 1.3) ===
JWT_SECRET=replace-with-32-byte-hex-from-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=480

# === LLM Providers (Stories 1.6, 2.x) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
VAIC_LLM_PROVIDER=openai
VAIC_LLM_BASE_URL=
VAIC_LLM_MODEL=DeepSeek-V4-Flash
VAIC_LLM_API_KEY=
VAIC_LLM_TIMEOUT_SECONDS=180
VAIC_EVALUATION_MAX_CONTEXT_TOKENS=32000
VAIC_EVALUATION_CHUNK_TOKENS=8000

# === MCP Client (Stories 1.4, 2.6) ===
MCP_SERVER_URL=
