# VAIC environment variables
# Copy to .env and fill in real values. Never commit .env.

# === Infrastructure (docker-compose) ===
POSTGRES_USER=vaic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vaic
POSTGRES_PORT=5432
REDIS_PORT=6379

# === Backend ===
# Sync SQLAlchemy URL (per architecture: sync mode) — Story 1.2 wires engine
DATABASE_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic
REDIS_URL=redis://localhost:6379/0

# === Auth (Story 1.3) ===
JWT_SECRET=replace-with-32-byte-hex-from-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=480

# === LLM Providers (Stories 1.6, 2.x) ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# === LLM config (model layer) — Story 1.6/2.x, .env-driven ===
# OpenAI-compatible Chat Completions endpoint (adapters/openai.py).
VAIC_LLM_BASE_URL=https://mkp-api.fptcloud.com/v1
# Adapter/provider id selected by app.core.adapters.registry.
VAIC_LLM_PROVIDER=openai
# Default model name passed as ModelRef.model_name to the adapter.
VAIC_LLM_MODEL=DeepSeek-V4-Flash
# API key for VAIC_LLM_BASE_URL. Falls back to ANTHROPIC_API_KEY if unset.
VAIC_LLM_API_KEY=
# Optional override for the orchestrator's decomposition-prompt model.
# Falls back to VAIC_LLM_MODEL when unset.
VAIC_ORCHESTRATOR_MODEL=

# === MCP Client (Stories 1.4, 2.6) ===
MCP_SERVER_URL=
