# Story 1.3 — Auth & Tenant Context Middleware
# Copy these into backend/.env (git-ignored). Adjust the DB name per stream.
VAIC_DATABASE_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic_13
VAIC_DATABASE_ADMIN_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic_13
# Application DB role — used to SET LOCAL ROLE in routes so RLS applies when
# the runtime DSN connects via a superuser. Leave empty in production where
# the DSN connects via vaic_app directly.
VAIC_APP_DB_ROLE=vaic_app
# JWT — generate a 32-byte hex secret with: openssl rand -hex 32
VAIC_JWT_SECRET=replace-with-32-byte-hex-from-openssl-rand-hex-32
VAIC_JWT_ALGORITHM=HS256
VAIC_JWT_TTL_MINUTES=480
