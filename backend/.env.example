# VAIC backend environment configuration
# Copy this file to `.env` and adjust values for your local setup.

# Sync SQLAlchemy DSN (runtime engine — subject to RLS policies)
VAIC_DATABASE_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic

# DSN for migrations + fixtures (BYPASSRLS-capable role)
VAIC_DATABASE_ADMIN_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic

# Postgres role used by the FastAPI app at runtime.
# MUST be a role without BYPASSRLS so RLS policies are enforced. In dev, we
# connect as the postgres superuser (which bypasses RLS) and SET LOCAL ROLE
# vaic_app inside transactions to drop privileges (Story 1-7's @tenant_aware_job
# decorator and Story 1-2's tests do this). Production deployments using a
# non-superuser DSN can leave this empty.
VAIC_APP_DB_ROLE=vaic_app

# Redis URL for arq background jobs
VAIC_REDIS_URL=redis://localhost:6379/0

# Auth (Story 1.3+)
VAIC_JWT_SECRET=replace-with-32-byte-hex-from-openssl-rand-hex-32
VAIC_JWT_ALGORITHM=HS256
VAIC_JWT_TTL_MINUTES=480
