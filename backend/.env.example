# VAIC — Backend app env (FastAPI + arq worker ONLY)
# Consumer: backend/app/core/settings.py (pydantic-settings, env_prefix="VAIC_",
# env_file=".env"). Loaded from the backend/ CWD, so this file MUST live at
# backend/.env — vars placed in the repo-root .env are NOT read by the backend.
# Copy to `backend/.env`. Never commit it (NFR-6).
#
# Naming rule: every backend field is read as VAIC_<UPPER_FIELD> (e.g. field
# `database_url` <- VAIC_DATABASE_URL). The ONLY exception is the bare
# ANTHROPIC_API_KEY (see LLM section) which uses a validation_alias.

# === Database ===
# VAIC_DATABASE_URL: sync SQLAlchemy DSN the app runs on (RLS policies apply).
# Host/port MUST match infra/.env (POSTGRES_PORT). Use a per-stream DB name for
# parallel test runs (e.g. vaic_13, vaic_14).
VAIC_DATABASE_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic

# VAIC_DATABASE_ADMIN_URL: DSN for migrations + fixtures with a BYPASSRLS-capable
# role (Alembic, test setup). Same host/port as above.
VAIC_DATABASE_ADMIN_URL=postgresql+psycopg://vaic:changeme@localhost:5432/vaic

# VAIC_APP_DB_ROLE: Postgres role the app SET LOCAL ROLE-s into at runtime.
# MUST NOT have BYPASSRLS so RLS is enforced. In dev we log in as the postgres
# superuser and drop to this role inside transactions. Leave empty in prod when
# the DSN already logs in as a non-superuser role.
VAIC_APP_DB_ROLE=vaic_app

# === Redis (arq background jobs) ===
# VAIC_REDIS_URL: host/port MUST match infra/.env (REDIS_PORT).
VAIC_REDIS_URL=redis://localhost:6379/0

# Private tenant-scoped chat uploads. Never expose this directory via StaticFiles.
VAIC_CHAT_FILES_ROOT=.chat-files

# === Auth (Story 1.3+) ===
# VAIC_JWT_SECRET: generate with `openssl rand -hex 32`.
VAIC_JWT_SECRET=replace-with-32-byte-hex-from-openssl-rand-hex-32
VAIC_JWT_ALGORITHM=HS256
# VAIC_JWT_TTL_MINUTES: access-token lifetime in minutes.
VAIC_JWT_TTL_MINUTES=480

# === CORS ===
# VAIC_CORS_ORIGINS: comma-separated browser origins allowed to call the API
# cross-origin. In dev the frontend usually reaches the API via the Vite proxy
# (same origin, no CORS needed); this covers direct VITE_API_BASE calls and
# production deploys served from a different origin.
VAIC_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# === Stored-credential encryption (Story 2.7 / NFR-6) ===
# VAIC_ENCRYPTION_KEY: Fernet key (urlsafe base64, 32 bytes) encrypting stored
# Integration auth headers at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAIC_ENCRYPTION_KEY=replace-with-a-urlsafe-base64-32-byte-fernet-key

# === Model Layer / LLM (AD-7, FR-26 provider-agnostic) ===
# VAIC_LLM_BASE_URL: OpenAI-compatible Chat Completions endpoint. Default is the
# FPT AI Marketplace "OpenAI Wrapper" root; point it at any compatible endpoint.
VAIC_LLM_BASE_URL=https://mkp-api.fptcloud.com/v1
# VAIC_LLM_PROVIDER: adapter id selected by select_llm_adapter (e.g. openai).
VAIC_LLM_PROVIDER=openai
# VAIC_LLM_MODEL: default model name passed as ModelRef.model_name.
VAIC_LLM_MODEL=DeepSeek-V4-Flash
# VAIC_ORCHESTRATOR_MODEL: optional override for the orchestrator decomposition
# prompt (Story 3.3). Falls back to VAIC_LLM_MODEL when empty.
VAIC_ORCHESTRATOR_MODEL=
# VAIC_LLM_TIMEOUT_SECONDS: hard per-request LLM timeout, set on the provider
# SDK client so a hung call aborts at this mark and raises (default 60).
VAIC_LLM_TIMEOUT_SECONDS=60
# VAIC_LLM_MAX_ATTEMPTS: max total LLM request attempts per Task incl. the
# first try (default 3 => first try + 2 retries with 2s/8s backoff).
VAIC_LLM_MAX_ATTEMPTS=3
# Audit Evaluation (V2) judge context sizing — chunk thresholds for the
# evidence-grounded LLM judge. Defaults match app/core/settings.py.
VAIC_EVALUATION_MAX_CONTEXT_TOKENS=32000
VAIC_EVALUATION_CHUNK_TOKENS=8000
# LLM API key: preferred var is VAIC_LLM_API_KEY; if unset, the bare
# ANTHROPIC_API_KEY (NOT VAIC_-prefixed, operator convention) is used via
# AliasChoices. Set ONE of the two — do not duplicate the same secret across
# both. NEVER commit a real key (NFR-6).
VAIC_LLM_API_KEY=
ANTHROPIC_API_KEY=replace-with-your-llm-provider-key

# === Optional secondary providers (only if used by model_catalog) ===
# Uncomment + set when routing to these providers instead of the default above.
# VAIC_OPENAI_API_KEY=
# Google Gemini uses the official OpenAI-compatible endpoint. Either
# VAIC_GOOGLE_API_KEY or GEMINI_API_KEY may be used (VAIC_* wins).
VAIC_GOOGLE_API_KEY=
GEMINI_API_KEY=
VAIC_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
VAIC_GEMINI_MODEL=gemini-3.5-flash
# VAIC_OLLAMA_BASE_URL=http://localhost:11434

# vaic_tools MCP tool server integration
VAIC_VAIC_TOOLS_ENABLED=false
VAIC_VAIC_TOOLS_BASE_URL=https://mcp.charcalavon.site
VAIC_VAIC_TOOLS_MCP_URL=https://mcp.charcalavon.site/mcp/
VAIC_VAIC_TOOLS_API_KEY=
