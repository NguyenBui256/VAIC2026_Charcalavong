# VAIC — Infrastructure env (docker-compose ONLY)
# Consumer: infra/docker-compose.yml (Postgres 18 + Redis 7.4).
# Copy to `infra/.env`, then start with:
#   docker compose --env-file infra/.env -f infra/docker-compose.yml up -d
# Never commit infra/.env (NFR-6).
#
# NOTE: this file holds ONLY the variables docker-compose interpolates.
# Backend app config lives in backend/.env (VAIC_-prefixed) — do NOT duplicate
# DSNs / secrets here. Single source of truth per consumer.

# --- Postgres ---
# POSTGRES_USER / _PASSWORD / _DB: superuser credentials + default database
# created inside the container on first boot.
POSTGRES_USER=vaic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vaic
# POSTGRES_PORT: HOST port mapped to the container's 5432. Connect the backend
# to this port. If you change it, you MUST update backend/.env
# VAIC_DATABASE_URL / VAIC_DATABASE_ADMIN_URL to the same port.
POSTGRES_PORT=5432

# --- Redis ---
# REDIS_PORT: HOST port mapped to the container's 6379. If you change it, update
# backend/.env VAIC_REDIS_URL to match.
REDIS_PORT=6379
